RewriteEngine On

# =========================================================
# 0) Excepción ACME (Let's Encrypt)
# =========================================================
RewriteRule ^\.well-known/acme-challenge/ - [L]

# =========================================================
# 1) Forzar HTTPS y dominio canónico sin www
# Cambia el dominio si aún estás en local
# =========================================================
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.ingenieriaforense\.es$ [NC]
RewriteRule ^ https://ingenieriaforense.es%{REQUEST_URI} [R=301,L]

# =========================================================
# 2) Redirigir /index.php a /
# =========================================================
RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s]|/) [NC]
RewriteRule ^index\.php$ / [R=301,L]

# =========================================================
# 3) Redirigir URLs con .php a versión limpia
# Ejemplo: /contacto.php -> /contacto
# =========================================================
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(?:[?\s]|/) [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# =========================================================
# 4) Si la URL limpia corresponde a un .php real, servirlo
# Ejemplo: /contacto -> contacto.php
# =========================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# =========================================================
# 5) Front controller
# Todo lo que no sea archivo o directorio real va a index.php
# =========================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
